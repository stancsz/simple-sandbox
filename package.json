    "@types/redis": "^4.0.11",
    "@types/tar": "^6.1.13",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "marked": "^17.0.4",
    "oclif": "^4.22.92",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "files": [
    "dist",
    "README.md",
    "docs/assets/logo.jpeg"
  ]
}
