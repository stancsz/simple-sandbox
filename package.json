{
  "name": "@stan-chen/simple-biosphere",
  "version": "0.2.9",
  "description": "The Technical Constitution of the Digital Biosphere. A self-correcting system that consumes environmental data to optimize its own existence.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "simple": "dist/cli.js",
    "simple-daemon": "bin/simple-daemon"
  },
  "scripts": {
    "start": "node --loader ts-node/esm src/cli.ts",
    "start:brain": "npx tsx src/mcp_servers/brain/index.ts",
    "daemon": "node --loader ts-node/esm src/daemon.ts",
    "start:slack": "node --loader ts-node/esm src/interfaces/slack.ts",
    "start:teams": "node --loader ts-node/esm src/interfaces/teams.ts",
    "demo": "npx tsx demos/simple-cli-showcase/run_demo.ts",
    "dev": "node --loader ts-node/esm --watch src/cli.ts",
    "docs:build": "node docs/website/build.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:stress": "vitest run tests/stress/",
    "test:showcase:biosphere": "vitest run tests/integration/digital_biosphere_showcase.test.ts",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/"
  },
  "keywords": [
    "cli",
    "agent",
    "coding-assistant",
    "llm",
    "mcp",
    "ai",
    "openai",
    "anthropic",
    "gemini",
    "litellm",
    "aider"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@anthropic-ai/sdk": "^0.79.0",
    "@browserbasehq/stagehand": "^3.0.8",
    "@clack/prompts": "^0.7.0",
    "@google/generative-ai": "^0.24.1",
    "@hubspot/api-client": "^13.4.0",
    "@kubernetes/client-node": "^1.4.0",
    "@lancedb/lancedb": "^0.27.0",
    "@linear/sdk": "^77.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@oclif/core": "^4.9.0",
    "@slack/bolt": "^4.6.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node-fetch": "^2.6.13",
    "@xenova/transformers": "^2.17.2",
    "ai": "^6.0.116",
    "apache-arrow": "^21.1.0",
    "async-mutex": "^0.5.0",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "body-parser": "^2.2.2",
    "botbuilder": "^4.23.3",
    "botframework-schema": "^4.23.3",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "cron-parser": "^5.5.0",
    "diff": "^8.0.3",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "fast-levenshtein": "^3.0.0",
    "glob": "^13.0.6",
    "gpt-tokenizer": "^3.4.0",
    "ioredis": "^5.10.0",
    "jsonrepair": "^3.13.3",
    "lru-cache": "^11.2.7",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "openclaw": "^2026.3.13",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "proper-lockfile": "^4.1.2",
    "redis": "^5.11.0",
    "simple-git": "^3.33.0",
    "simple-statistics": "^7.8.9",
    "sqlite-vec": "^0.1.7",
    "tar": "^6.2.1",
    "ts-morph": "^27.0.2",
    "turndown": "^7.2.2",
    "xero-node": "^14.0.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
